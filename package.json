{
  "name": "budget",
  "version": "0.0.1",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm build-better-sqlite3 && pnpm prisma-build && pnpm schema && pnpm relay-compiler",
    "build-better-sqlite3": "cd node_modules/.pnpm/better-sqlite3@12.9.0/node_modules/better-sqlite3 && pnpm prebuild-install || npm run build-release; cd - ",
    "relay": "relay-compiler && npm run lint",
    "schema": "pnpm ts-node -O '{\"module\":\"commonjs\"}' ./app/scripts/schema.ts && pnpm prettier app/graphql/schema.graphql --write",
    "import": "pnpm ts-node -O '{\"module\":\"commonjs\"}' ./app/scripts/import.ts",
    "currencies": "pnpm ts-node -O '{\"module\":\"commonjs\"}' ./app/scripts/currencies.ts",
    "dev": "pnpm ts-node -O '{\"module\":\"commonjs\"}' ./app/scripts/serve.ts dev",
    "build": "next build",
    "start": "pnpm ts-node -O '{\"module\":\"commonjs\"}' ./app/scripts/serve.ts start",
    "lint": "next typegen && tsc --noemit; eslint .",
    "prisma-build": "pnpm prisma generate",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e": "playwright test --reporter=list",
    "e2e:ui": "playwright test --ui",
    "e2e:seed": "DATABASE_FILE=file:./e2e/golden.sqlite pnpm ts-node -O '{\"module\":\"commonjs\"}' ./tests/e2e/helpers/seed.ts",
    "e2e:setup": "mkdir -p e2e && pnpm exec prisma db push --url file:./e2e/golden.sqlite && pnpm e2e:seed",
    "prepare": "husky"
  },
  "dependencies": {
    "@heroui/react": "3.2.1",
    "@heroui/styles": "3.2.1",
    "@hublaw/ofx-parser": "^1.1.0",
    "@nextui-org/react": "^2.6.11",
    "@nextui-org/use-infinite-scroll": "^2.2.2",
    "@pothos/core": "^4.12.0",
    "@pothos/plugin-errors": "^4.9.0",
    "@pothos/plugin-prisma": "^4.14.3",
    "@pothos/plugin-prisma-utils": "^1.3.3",
    "@pothos/plugin-relay": "^4.7.0",
    "@pothos/plugin-simple-objects": "^4.1.3",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@react-hook/resize-observer": "^2.0.2",
    "@react-stately/data": "^3.16.0",
    "@types/react-dom": "^19.2.3",
    "chroma-js": "^3.2.0",
    "commander": "^14.0.3",
    "csv-parse": "^6.2.1",
    "date-format-parse": "^0.2.7",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "eslint-plugin-jest": "^29.15.2",
    "format-number-with-string": "^0.0.2",
    "framer-motion": "^12.38.0",
    "graphql-scalars": "^1.25.0",
    "graphql-yoga": "^5.21.0",
    "iconv-lite": "^0.7.2",
    "next": "^16.2.6",
    "object-hash": "^3.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-relay": "^20.1.1",
    "relay-nextjs": "^3.0.1",
    "relay-runtime": "^20.1.1",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/env": "^16.2.6",
    "@next/eslint-plugin-next": "^16.2.6",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@tsconfig/node18": "^18.2.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chroma-js": "^3.1.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@types/object-hash": "^3.0.6",
    "@types/react": "^19.2.14",
    "@types/react-relay": "^18.2.1",
    "@types/relay-runtime": "^20.1.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "autoprefixer": "^10.5.0",
    "babel": "^6.23.0",
    "babel-plugin-relay": "^20.1.1",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-relay": "^2.0.0",
    "graphql": "^16.14.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.14",
    "pothos-prisma-generator": "^1.3.11",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-prisma": "^5.0.0",
    "prettier-plugin-sql": "^0.20.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "relay-compiler": "^20.1.1",
    "relay-test-utils": "^21.0.1",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "undici": "^8.5.0"
  }
}
