generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
  output          = "node_modules/.prisma/client"
}

generator pothos {
  provider = "pothos-prisma-generator"
  previewFeatures = ["views"]
  prismaUtils     = "true"
  output   = "app/graphql/pothos-prisma.generated.ts"
}

datasource db {
  provider = "sqlite"
}

model Transaction {
  id               String                     @id @unique
  source           String
  date             DateTime
  description      String
  amount           Int
  amount_converted Int?
  currency         String
  categories       TransactionsOnCategories[]
  completed        Boolean                    @default(false)

  @@map("transactions")
}

model Category {
  id               Int                        @id @default(autoincrement())
  name             String
  parentCategory   Category?                  @relation("ParentCategory", fields: [parentCategoryId], references: [id])
  parentCategoryId Int?
  subCategories    Category[]                 @relation("ParentCategory")
  transactions     TransactionsOnCategories[]
  statistic        Statistic[]

  @@unique([name, parentCategoryId])
  @@map("categories")
}

model CurrencyExchangeRate {
  id     String   @id @unique
  date   DateTime
  base   String
  target String
  rate   Float

  @@unique([date, base, target])
  @@map("currency_exchange_rates")
}

view CurrencyExchangeRateClaim {
  id       String   @unique
  date     DateTime
  currency String

  @@map("currency_exchange_rate_clames")
}

model TransactionsOnCategories {
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  transactionId String

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId Int

  amount           Int
  amount_converted Int

  @@id([transactionId, categoryId])
  @@map("transactions2categories")
}

view StatisticPerMonths {
  id      String @unique
  year    Int
  month   Int
  income  Int
  outcome Int

  @@map("transactions_statistic_per_months")
}

view StatisticPerSource {
  id      String @unique
  income  Int
  outcome Int
  source  String

  @@map("transactions_statistic_per_source")
}

view Statistic {
  id      String @unique
  monthId String
  income  Int
  outcome Int

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId Int

  @@map("transactions_statistic")
}
